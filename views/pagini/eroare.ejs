<!DOCTYPE html>
<html lang="ro">

<head>
    <%- include('../fragmente/head.ejs') %>
    <title><%= titlu %></title>
    <style>
        .eroare-container {
            text-align: center;
            padding: 60px 20px;
            max-width: 600px;
            margin: 0 auto;
        }
        .eroare-img {
            max-width: 100%;
            height: auto;
            margin-top: 25px;
            border-radius: 8px;
        }
    </style>
</head>

<body>
    <%- include('../fragmente/header.ejs') %>

    <main>
        <div class="eroare-container">
            <h2><%= titlu %></h2>
            <p><%= text %></p>
            
            <% if (imagine) { %>
                <img src="<%= imagine %>" alt="Imagine eroare" class="eroare-img" />
            <% } %>
            
            <br><br>
            <a href="/" style="display: inline-block; margin-top: 20px; padding: 10px 20px; background: #1a1a1a; color: #fff; text-decoration: none; border-radius: 4px;">
                Înapoi în universul Vinyllium
            </a>
        </div>
    </main>

    <%- include('../fragmente/footer.ejs') %>
</body>
</html>